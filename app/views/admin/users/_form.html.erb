<%= form_with model: [:admin, user], class: "space-y-5" do |f| %>
  <% if user.errors.any? %>
    <div class="flash-alert">
      <% user.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :display_name, class: "label-text" %>
    <%= f.text_field :display_name, class: "input-field", required: true %>
  </div>

  <div>
    <%= f.label :email_address, "Email", class: "label-text" %>
    <%= f.email_field :email_address, class: "input-field", required: true %>
  </div>

  <div>
    <%= f.label :password, class: "label-text" %>
    <%= f.password_field :password, class: "input-field", required: user.new_record?, placeholder: user.persisted? ? "Leave blank to keep current" : "" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "label-text" %>
    <%= f.password_field :password_confirmation, class: "input-field", required: user.new_record? %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :admin, class: "w-4 h-4 rounded border-oscar-border accent-oscar-gold" %>
    <%= f.label :admin, "Administrator", class: "text-sm text-oscar-text" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "btn btn-gold" %>
    <%= link_to "Cancel", admin_users_path, class: "btn btn-outline no-underline" %>
  </div>
<% end %>
