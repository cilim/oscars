<% content_for(:title, "Preview — #{@data.dig('season', 'name')}") %>

<div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
  <div>
    <div class="mb-1">
      <%= link_to "← Scrape again", new_admin_scrape_path, class: "text-sm text-oscar-muted hover:text-oscar-text no-underline transition-colors" %>
    </div>
    <h1 class="text-3xl font-bold text-oscar-gold">Preview & Edit</h1>
    <p class="text-oscar-muted mt-1">Review the scraped data, make corrections, then import.</p>
  </div>
</div>

<%= form_with url: import_admin_scrapes_path, method: :post, data: { turbo: false } do |f| %>

  <%# Season info %>
  <div class="card mb-6">
    <h2 class="text-xs font-semibold text-oscar-muted uppercase tracking-wider mb-3">Season</h2>
    <div class="flex gap-3 flex-wrap">
      <div class="flex-1 min-w-[220px]">
        <label class="label-text">Name</label>
        <input type="text" name="season[name]" value="<%= @data['season']['name'] %>"
               class="input-field" required>
      </div>
      <div class="w-28">
        <label class="label-text">Year</label>
        <input type="number" name="season[year]" value="<%= @data['season']['year'] %>"
               class="input-field" required>
      </div>
    </div>
  </div>

  <%# Summary + top import button %>
  <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
    <p class="text-oscar-muted text-sm">
      <strong class="text-oscar-text"><%= @data['categories'].length %></strong> categories &middot;
      <strong class="text-oscar-text"><%= @data['categories'].sum { |c| (c['nominees'] || []).length } %></strong> nominees
    </p>
    <input type="submit" value="★ Import Season" class="btn btn-gold cursor-pointer">
  </div>

  <%# Categories %>
  <div class="space-y-3">
    <% @data['categories'].each_with_index do |cat, ci| %>
      <div class="card p-0 overflow-hidden"
           data-controller="scrape-category"
           data-scrape-category-category-index-value="<%= ci %>"
           data-scrape-category-has-person-value="<%= cat['has_person'] %>">

        <%# Category header row %>
        <div class="flex items-center gap-3 px-4 py-3 bg-oscar-surface border-b border-oscar-border flex-wrap">
          <input type="text" name="categories[<%= ci %>][name]" value="<%= cat['name'] %>"
                 class="input-field flex-1 min-w-[160px] text-sm font-semibold py-1.5" required>

          <label class="flex items-center gap-2 text-sm text-oscar-muted cursor-pointer whitespace-nowrap select-none">
            <input type="hidden"   name="categories[<%= ci %>][has_person]" value="0">
            <input type="checkbox" name="categories[<%= ci %>][has_person]" value="1"
                   <%= 'checked' if cat['has_person'] %> class="rounded cursor-pointer">
            Has person
          </label>

          <span class="text-xs text-oscar-muted flex-shrink-0"><%= (cat['nominees'] || []).length %> nominees</span>
        </div>

        <%# Nominee rows %>
        <div class="px-4 pt-3 pb-1 space-y-1.5" data-scrape-category-target="nomineeList">
          <% (cat['nominees'] || []).each_with_index do |nom, ni| %>
            <div class="flex gap-2 items-center" data-nominee-row>
              <input type="text"
                     name="categories[<%= ci %>][nominees][<%= ni %>][movie]"
                     value="<%= nom['movie'] %>" placeholder="Movie"
                     class="input-field flex-1 text-xs py-1.5" required>
              <% if cat['has_person'] %>
                <input type="text"
                       name="categories[<%= ci %>][nominees][<%= ni %>][person]"
                       value="<%= nom['person'] %>" placeholder="Person"
                       class="input-field w-36 text-xs py-1.5">
              <% end %>
              <input type="text"
                     name="categories[<%= ci %>][nominees][<%= ni %>][poster_url]"
                     value="<%= nom['poster_url'] %>" placeholder="Poster URL (optional)"
                     class="input-field w-52 text-xs py-1.5">
              <button type="button"
                      data-action="click->scrape-category#removeNominee"
                      class="btn btn-danger btn-sm flex-shrink-0 px-2 leading-none">✕</button>
            </div>
          <% end %>
        </div>

        <%# Add nominee %>
        <div class="px-4 pb-3 pt-2">
          <button type="button"
                  data-action="click->scrape-category#addNominee"
                  class="btn btn-outline btn-sm text-xs">+ Add Nominee</button>
        </div>

      </div>
    <% end %>
  </div>

  <%# Bottom import button %>
  <div class="mt-6 flex justify-end">
    <input type="submit" value="★ Import Season" class="btn btn-gold btn-lg cursor-pointer">
  </div>

<% end %>
