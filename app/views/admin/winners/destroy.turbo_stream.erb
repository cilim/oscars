<%= turbo_stream.replace "season_category_#{@season_category_id}_winner" do %>
  <%= render "scoreboards/category_card", sc: @season_category, season: @season, is_admin: true %>
<% end %>

<%= turbo_stream.replace "leaderboard" do %>
  <%= render "scoreboards/leaderboard", scoreboard_data: @scoreboard_data %>
<% end %>

<%= turbo_stream.replace "category-progress" do %>
  <%= render "scoreboards/progress", season_categories: @season_categories %>
<% end %>
