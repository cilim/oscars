<%= form_with model: [:admin, season], class: "space-y-5" do |f| %>
  <% if season.errors.any? %>
    <div class="flash-alert">
      <ul class="list-disc list-inside space-y-1">
        <% season.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "label-text" %>
    <%= f.text_field :name, class: "input-field", placeholder: "e.g. 2026 Oscars" %>
  </div>

  <div>
    <%= f.label :year, class: "label-text" %>
    <%= f.number_field :year, class: "input-field", placeholder: "e.g. 2026" %>
  </div>

  <div class="flex gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :locked, class: "w-4 h-4 accent-oscar-gold" %>
      <span class="text-sm text-oscar-text">Lock picks</span>
    </label>

    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :archived, class: "w-4 h-4 accent-oscar-gold" %>
      <span class="text-sm text-oscar-text">Archived</span>
    </label>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "btn btn-gold" %>
    <%= link_to "Cancel", admin_seasons_path, class: "btn btn-outline no-underline" %>
  </div>
<% end %>
