<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold text-oscar-gold">Seasons</h1>
  <%= link_to "New Season", new_admin_season_path, class: "btn btn-gold no-underline" %>
</div>

<%# Import from YAML data files %>
<% available_years = Dir[Rails.root.join("db/data/*.yml")].map { |f| File.basename(f, ".yml") }.sort %>
<% if available_years.any? %>
  <div class="card mb-8">
    <h3 class="text-sm font-semibold text-white mb-3">Import from data file</h3>
    <div class="flex flex-wrap gap-2">
      <% available_years.each do |year| %>
        <%= button_to "Import #{year}", admin_import_path(year: year),
            class: "btn btn-outline btn-sm",
            data: { turbo_confirm: "Import/update data for #{year}? This is safe to run multiple times." } %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @seasons.any? %>
  <div class="space-y-4">
    <% @seasons.each do |season| %>
      <div class="card flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-white"><%= season.name %></h2>
          <p class="text-oscar-muted text-sm">
            <%= season.season_categories.count %> categories &middot;
            <%= season.players.count %> players
            <% if season.locked? %>
              &middot; <span class="text-red-400">Locked</span>
            <% end %>
            <% if season.archived? %>
              &middot; <span class="text-oscar-muted">Archived</span>
            <% end %>
          </p>
        </div>
        <div class="flex gap-2">
          <%= link_to "Manage", admin_season_path(season), class: "btn btn-outline btn-sm no-underline" %>
          <%= link_to "Edit", edit_admin_season_path(season), class: "btn btn-outline btn-sm no-underline" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card text-center py-12">
    <p class="text-oscar-muted text-lg">No seasons yet. Create your first one!</p>
  </div>
<% end %>
