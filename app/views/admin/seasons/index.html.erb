<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold text-oscar-gold">Seasons</h1>
  <div class="flex gap-2">
    <%= link_to "Scrape Nominations", new_admin_scrape_path, class: "btn btn-outline no-underline" %>
    <%= link_to "New Season", new_admin_season_path, class: "btn btn-gold no-underline" %>
  </div>
</div>

<%# Import from YAML data files %>
<% available_years = Dir[Rails.root.join("db/data/*.yml")].map { |f| File.basename(f, ".yml") }.sort %>
<% if available_years.any? %>
  <div class="card mb-8">
    <h3 class="text-sm font-semibold text-oscar-text mb-3">Import from data file</h3>
    <div class="flex flex-wrap gap-2">
      <% available_years.each do |year| %>
        <%= button_to "Import #{year}", admin_import_path(year: year),
            class: "btn btn-outline btn-sm",
            data: { turbo_confirm: "Import/update data for #{year}? This is safe to run multiple times." } %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="card mb-8">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h3 class="text-sm font-semibold text-oscar-text mb-2">Database backup</h3>
      <p class="text-sm text-oscar-muted max-w-2xl">
        Download a full JSON backup of the current database, or restore the app by importing a previously downloaded backup file.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
      <%= link_to "Download backup",
          admin_database_backup_path,
          class: "btn btn-outline no-underline" %>

      <%= form_with url: import_admin_database_backup_path, multipart: true, class: "flex flex-col gap-2 sm:flex-row sm:items-end" do |form| %>
        <div>
          <%= form.label :backup_file, "Import backup JSON", class: "block text-xs font-semibold uppercase tracking-wider text-oscar-muted mb-1" %>
          <%= form.file_field :backup_file, accept: "application/json,.json", class: "block w-full text-sm text-oscar-text" %>
        </div>
        <%= form.submit "Restore backup",
            class: "btn btn-gold",
            data: {
              turbo_confirm: "Replace the entire database with this backup? This deletes all current data and may sign you out."
            } %>
      <% end %>
    </div>
  </div>
</div>

<% if @seasons.any? %>
  <div class="space-y-4">
    <% @seasons.each do |season| %>
      <div class="card flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-oscar-text"><%= season.name %></h2>
          <p class="text-oscar-muted text-sm">
            <%= season.season_categories.count %> categories &middot;
            <%= season.players.count %> players
            <% if season.locked? %>
              &middot; <span class="text-oscar-red">Locked</span>
            <% end %>
            <% if season.archived? %>
              &middot; <span class="text-oscar-muted">Archived</span>
            <% end %>
          </p>
        </div>
        <div class="flex gap-2">
          <%= link_to "Manage", admin_season_path(season), class: "btn btn-outline btn-sm no-underline" %>
          <%= link_to "Edit", edit_admin_season_path(season), class: "btn btn-outline btn-sm no-underline" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card text-center py-12">
    <p class="text-oscar-muted text-lg">No seasons yet. Create your first one!</p>
  </div>
<% end %>
