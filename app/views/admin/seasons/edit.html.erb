<h1 class="text-3xl font-bold text-oscar-gold mb-8">Edit Season</h1>
<div class="card max-w-lg">
  <%= render "form", season: @season %>
</div>

<div class="mt-6">
  <% pick_count = Pick.joins(:player).where(players: { season: @season }).count %>
  <% confirm_msg = if pick_count > 0
      "WARNING: #{pick_count} player pick#{"s" if pick_count != 1} will be permanently deleted along with all categories, nominees, and players. This cannot be undone. Proceed?"
    else
      "Delete this season and all its categories, nominees, and players? This cannot be undone."
    end %>
  <%= button_to "Delete Season", admin_season_path(@season), method: :delete,
      class: "btn btn-danger btn-sm",
      data: { turbo_confirm: confirm_msg } %>
</div>
