<% content_for(:title, "Make Picks - #{@season.name}") %>

<div class="mb-8">
  <div class="flex items-center justify-between flex-wrap gap-4">
    <div>
      <h1 class="text-3xl font-bold text-oscar-gold">Make Your Picks</h1>
      <p class="text-oscar-muted mt-1"><%= @season.name %> &middot; Picks save automatically</p>
    </div>
    <%= link_to "Back to Season", season_path(@season), class: "btn btn-outline no-underline" %>
  </div>
</div>

<%# Progress bar — updates live as the user makes picks %>
<div class="mb-6"
     data-controller="picks-progress"
     data-picks-progress-total-value="<%= @season_categories.size %>"
     data-action="picks-carousel:changed@window->picks-progress#update">
  <div class="relative h-9 rounded-full overflow-hidden bg-oscar-surface border border-oscar-border">
    <div class="absolute inset-y-0 left-0 bg-oscar-gold flex items-center px-4 transition-all duration-500"
         style="width: 0%" hidden
         data-picks-progress-target="fill">
      <span class="text-xs font-bold text-white whitespace-nowrap overflow-hidden"
            data-picks-progress-target="pickedLabel" hidden></span>
    </div>
    <div class="absolute inset-y-0 right-0 flex items-center px-4">
      <span class="text-xs font-semibold text-oscar-muted whitespace-nowrap"
            data-picks-progress-target="remainingLabel" hidden></span>
    </div>
  </div>
</div>

<%= form_with url: season_picks_path(@season), method: :patch, class: "space-y-6",
              data: { controller: "picks-form",
                      "picks-form-season-id-value": @season.id,
                      action: "submit->picks-form#clearStorage" } do |f| %>

  <% @season_categories.each do |sc| %>
    <% pick = @picks_by_category[sc.id] || Pick.new %>

    <div class="card"
         data-controller="picks-carousel"
         data-picks-carousel-season-id-value="<%= @season.id %>"
         data-picks-carousel-category-id-value="<%= sc.id %>">

      <%# Hidden inputs drive the form submission — JS keeps them in sync %>
      <input type="hidden" name="picks[<%= sc.id %>][think_will_win_id]"
             value="<%= pick.think_will_win_id %>"
             data-picks-carousel-target="thinkInput">
      <input type="hidden" name="picks[<%= sc.id %>][want_to_win_id]"
             value="<%= pick.want_to_win_id %>"
             data-picks-carousel-target="wantInput">

      <%# Card header: category name + current selection summary %>
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h3 class="text-xl font-bold text-oscar-text"><%= sc.category_name %></h3>
          <p class="text-oscar-muted text-xs mt-0.5"><%= sc.has_person ? "Person & film" : "Film" %></p>
        </div>

        <div class="text-right text-xs shrink-0 space-y-1">
          <div class="flex items-center gap-1.5 justify-end">
            <span class="font-black text-[10px] text-white bg-sky-500 px-1.5 py-0.5 rounded leading-none" title="Think will win">🧠</span>
            <span data-picks-carousel-target="thinkSummary" class="text-oscar-muted">—</span>
          </div>
          <div class="flex items-center gap-1.5 justify-end">
            <span class="font-black text-[10px] text-white bg-violet-500 px-1.5 py-0.5 rounded leading-none" title="Want to win">❤️</span>
            <span data-picks-carousel-target="wantSummary" class="text-oscar-muted">—</span>
          </div>
        </div>
      </div>

      <%# Legend %>
      <div class="flex gap-4 text-[11px] text-oscar-muted mb-3">
        <span><span title="Think will win">🧠</span> Think will win <span class="text-oscar-gold font-semibold">(5 pts)</span></span>
        <span><span title="Want to win">❤️</span> Want to win <span class="text-oscar-muted">(2 pts)</span></span>
      </div>

      <%# Carousel container with prev/next arrows %>
      <div class="relative -mx-2 px-2">
        <%# Prev arrow %>
        <button type="button"
                data-action="click->picks-carousel#prev"
                class="absolute left-0 top-[72px] -translate-y-1/2 z-10 w-7 h-7 flex items-center justify-center rounded-full bg-white border border-oscar-border shadow text-oscar-muted hover:text-oscar-text hover:shadow-md transition-all text-lg leading-none select-none">
          &#8249;
        </button>

        <%# Scrollable track %>
        <div class="picks-track overflow-x-auto flex gap-3 snap-x snap-mandatory scroll-smooth px-4 pb-2"
             data-picks-carousel-target="track">

          <% sc.nominees.each do |nom| %>
            <%# Card: no fixed width — grows to fit whitespace-nowrap title %>
            <div class="flex-shrink-0 snap-center select-none flex flex-col items-center"
                 data-slide
                 data-nominee-id="<%= nom.id %>"
                 data-nominee-name="<%= nom.display_name %>">

              <%# Poster: fixed 120×180 px so all cards have identical poster size %>
              <div class="relative rounded-lg overflow-hidden bg-oscar-surface transition-all duration-150 flex-shrink-0"
                   style="width: 120px; height: 180px;"
                   data-poster-wrap>
                <% if nom.poster_url.present? %>
                  <img src="<%= nom.poster_url %>"
                       alt="<%= nom.movie_name %>"
                       class="w-full h-full object-cover">
                <% else %>
                  <div class="w-full h-full flex flex-col items-center justify-center gap-2 p-2">
                    <svg class="w-6 h-6 text-oscar-border" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18 4H6C4.9 4 4 4.9 4 6v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H6V6h12v12zm-4.5-6L11 15.5 9 13l-3 4h12l-4.5-6z"/>
                    </svg>
                    <span class="text-[10px] text-oscar-muted text-center leading-tight"><%= nom.movie_name %></span>
                  </div>
                <% end %>

                <%# 🧠 badge — top-left, revealed when selected %>
                <span data-think-badge hidden
                      class="absolute top-1.5 left-1.5 bg-sky-500 text-white text-[10px] font-black px-1.5 py-0.5 rounded leading-none shadow-sm" title="Think will win">🧠</span>

                <%# ❤️ badge — top-right, revealed when selected %>
                <span data-want-badge hidden
                      class="absolute top-1.5 right-1.5 bg-violet-500 text-white text-[10px] font-black px-1.5 py-0.5 rounded leading-none shadow-sm" title="Want to win">❤️</span>
              </div>

              <%# Nominee name — single line, card widens to fit %>
              <p class="text-[12px] text-oscar-text font-medium text-center whitespace-nowrap mt-2 mb-2">
                <%= nom.display_name %>
              </p>

              <%# 🧠 / ❤️ toggle buttons — stretch to full card width %>
              <div class="flex gap-1 w-full">
                <button type="button"
                        data-action="click->picks-carousel#toggleThink"
                        data-nominee-id="<%= nom.id %>"
                        data-think-btn
                        data-active="false"
                        title="Think will win"
                        class="flex-1 text-xs py-1.5 rounded-md border font-bold transition-colors leading-none min-w-[36px]">
                  🧠
                </button>
                <button type="button"
                        data-action="click->picks-carousel#toggleWant"
                        data-nominee-id="<%= nom.id %>"
                        data-want-btn
                        data-active="false"
                        title="Want to win"
                        class="flex-1 text-xs py-1.5 rounded-md border font-bold transition-colors leading-none min-w-[36px]">
                  ❤️
                </button>
              </div>

            </div>
          <% end %>

        </div>

        <%# Next arrow %>
        <button type="button"
                data-action="click->picks-carousel#next"
                class="absolute right-0 top-[72px] -translate-y-1/2 z-10 w-7 h-7 flex items-center justify-center rounded-full bg-white border border-oscar-border shadow text-oscar-muted hover:text-oscar-text hover:shadow-md transition-all text-lg leading-none select-none">
          &#8250;
        </button>
      </div>

    </div>
  <% end %>

<% end %>
