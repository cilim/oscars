<% leader_score = scoreboard_data.first&.dig(:total_score).to_i %>

<div id="leaderboard" class="card">
  <h2 class="text-xl font-bold text-oscar-gold mb-4 flex items-center gap-2">
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9 9H2l6 4.5L5.5 21 12 16.5 18.5 21 16 13.5 22 9h-7z"/></svg>
    Leaderboard
  </h2>

  <% if scoreboard_data.any? %>
    <div class="space-y-2">
      <% scoreboard_data.each_with_index do |entry, i| %>
        <% gap = leader_score - entry[:total_score] %>
        <div class="flex items-center gap-3 py-2.5 px-3 rounded-lg
                    <%= i == 0 ? 'bg-oscar-gold/10 border border-oscar-gold/30' : 'bg-oscar-surface' %>">
          <%# Rank badge %>
          <span class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-full text-xs font-bold
                       <%= case i
                           when 0 then 'bg-oscar-gold text-white'
                           when 1 then 'bg-gray-400 text-white'
                           when 2 then 'bg-amber-700 text-white'
                           else 'bg-oscar-surface text-oscar-muted border border-oscar-border'
                           end %>">
            <%= i + 1 %>
          </span>

          <%# Name %>
          <span class="flex-1 font-semibold text-sm truncate <%= i == 0 ? 'text-oscar-gold-dark' : 'text-oscar-text' %>">
            <%= entry[:player_name] %>
          </span>

          <%# Score + gap %>
          <div class="text-right flex-shrink-0">
            <span class="text-xl font-mono font-bold <%= i == 0 ? 'text-oscar-gold-dark' : 'text-oscar-text' %>">
              <%= entry[:total_score] %>
            </span>
            <% if i > 0 && gap > 0 %>
              <div class="text-[10px] text-oscar-muted">−<%= gap %> pts</div>
            <% else %>
              <div class="text-[10px] text-oscar-muted">
                <span title="Think will win"><%= entry[:think_score] %>🧠</span>
                +
                <span title="Want to win"><%= entry[:want_score] %>❤️</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-oscar-muted text-center py-4">No players yet</p>
  <% end %>
</div>
