<div id="leaderboard" class="card sticky top-24">
  <h2 class="text-2xl font-bold text-oscar-gold mb-6 flex items-center gap-2">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9 9H2l6 4.5L5.5 21 12 16.5 18.5 21 16 13.5 22 9h-7z"/></svg>
    Leaderboard
  </h2>

  <% if scoreboard_data.any? %>
    <div class="space-y-3">
      <% scoreboard_data.each_with_index do |entry, i| %>
        <div class="flex items-center justify-between py-3 px-4 rounded-lg transition-all duration-300
                    <%= i == 0 ? 'bg-oscar-gold/10 border border-oscar-gold/30' : 'bg-oscar-deeper' %>">
          <div class="flex items-center gap-3">
            <span class="w-8 h-8 flex items-center justify-center rounded-full text-sm font-bold
                        <%= case i
                            when 0 then 'bg-oscar-gold text-oscar-dark'
                            when 1 then 'bg-gray-400 text-oscar-dark'
                            when 2 then 'bg-amber-700 text-white'
                            else 'bg-oscar-deeper text-oscar-muted border border-oscar-border'
                            end %>">
              <%= i + 1 %>
            </span>
            <span class="font-semibold <%= i == 0 ? 'text-oscar-gold' : 'text-white' %>">
              <%= entry[:player_name] %>
            </span>
          </div>
          <div class="text-right">
            <span class="text-2xl font-mono font-bold <%= i == 0 ? 'text-oscar-gold' : 'text-white' %>">
              <%= entry[:total_score] %>
            </span>
            <div class="text-xs text-oscar-muted">
              <span title="Think will win points"><%= entry[:think_score] %>t</span>
              +
              <span title="Want to win points"><%= entry[:want_score] %>w</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-oscar-muted text-center py-4">No players yet</p>
  <% end %>
</div>
