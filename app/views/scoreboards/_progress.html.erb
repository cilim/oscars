<% total_count     = season_categories.size %>
<% announced_count = season_categories.count { |sc| sc.winner.present? } %>
<% pending_count   = total_count - announced_count %>
<% pct             = total_count > 0 ? (announced_count.to_f / total_count * 100).round(2) : 0 %>

<div id="category-progress" class="relative h-9 rounded-full overflow-hidden bg-oscar-surface border border-oscar-border">
  <%# Gold fill — grows as winners are announced %>
  <div class="absolute inset-y-0 left-0 bg-oscar-gold flex items-center px-4 transition-all duration-700"
       style="width: <%= pct %>%">
    <% if announced_count > 0 %>
      <span class="text-xs font-bold text-white whitespace-nowrap overflow-hidden">
        ★ <%= announced_count %> announced
      </span>
    <% end %>
  </div>

  <%# Pending label — right side %>
  <% if pending_count > 0 %>
    <div class="absolute inset-y-0 right-0 flex items-center px-4">
      <span class="text-xs font-semibold text-oscar-muted whitespace-nowrap"><%= pending_count %> pending</span>
    </div>
  <% end %>

  <%# When fully announced, show centered "All announced" %>
  <% if pending_count == 0 && announced_count > 0 %>
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="text-xs font-bold text-white">★ All <%= announced_count %> announced</span>
    </div>
  <% end %>
</div>
